<div class="bg-white shadow flex items-center justify-between px-4 py-3">
  <a class="text-lg font-semibold text-slate-800" href="">Question Bank</a>
  <div class="flex items-center gap-3">
    <small class="text-sm text-gray-500">v1.0</small>
    <button title="Navigation menu" class="p-2 rounded hover:bg-gray-100 md:hidden" @onclick="ToggleNavMenu" aria-expanded="@(collapseNavMenu ? "true" : "false")">
      @if (!collapseNavMenu)
      {
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-700" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 5h14a1 1 0 010 2H3a1 1 0 110-2zm0 4h14a1 1 0 010 2H3a1 1 0 110-2zm0 4h14a1 1 0 010 2H3a1 1 0 110-2z" clip-rule="evenodd" /></svg>
      }
      else
      {
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-700" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
      }
    </button>
  </div>
</div>

@if (collapseNavMenu)
{
  <div class="fixed inset-0 z-40 bg-black bg-opacity-30" @onclick="ToggleNavMenu"></div>
}

<div class="@MenuPanelClass">
  <div class="mb-3">
    <input class="w-full px-3 py-2 border rounded-md text-sm" placeholder="Quick jump (type to filter)" @bind="search" @bind:event="oninput" />
  </div>
  <nav class="flex flex-col">
    <a class="px-3 py-2 rounded hover:bg-gray-100 text-sm text-gray-700" href="" Match="NavLinkMatch.All" hidden="@(!Matches("Home"))">
      <span class="oi oi-home" aria-hidden="true"></span> Home
    </a>
    <a class="px-3 py-2 rounded hover:bg-gray-100 text-sm text-gray-700" href="pdfviewer" hidden="@(!Matches("PDF Viewer"))">
      <span class="oi oi-paperclip" aria-hidden="true"></span> PDF Viewer
    </a>
  </nav>
  <div class="mt-4 text-xs text-gray-500">Tip: use the quick jump to find pages faster.</div>
</div>

@code {
  private bool collapseNavMenu = false;
  private string search = string.Empty;

  private string MenuPanelClass => (collapseNavMenu ? "translate-x-0 " : "-translate-x-full ") + "fixed top-0 left-0 z-50 h-full w-64 bg-gray-50 p-3 transform transition-transform duration-300 shadow-lg md:static md:translate-x-0";

  private void ToggleNavMenu()
  {
    collapseNavMenu = !collapseNavMenu;
  }

  private bool Matches(string label)
  {
    if (string.IsNullOrWhiteSpace(search)) return true;
    return label.Contains(search, StringComparison.OrdinalIgnoreCase);
  }
}
